#!/usr/bin/env bash
# Enforces Udacity Git Commit Style Guide:
# https://udacity.github.io/git-styleguide/

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

TYPES="feat|fix|docs|style|refactor|test|chore"

# Skip merge commits and fixup commits
if echo "$COMMIT_MSG" | grep -qE "^(Merge|fixup!|squash!)"; then
  exit 0
fi

# --- Rule 1: type must be valid ---
if ! echo "$COMMIT_MSG" | grep -qE "^($TYPES): "; then
  echo ""
  echo "  ✗ COMMIT REJECTED — Invalid commit message format"
  echo ""
  echo "  Expected format:  <type>: <Subject>"
  echo "  Your message:     $COMMIT_MSG"
  echo ""
  echo "  Valid types: feat | fix | docs | style | refactor | test | chore"
  echo ""
  echo "  Example: feat: Add weekly reset timer widget"
  echo ""
  exit 1
fi

# --- Rule 2: subject must start with a capital letter ---
SUBJECT=$(echo "$COMMIT_MSG" | sed -E "s/^($TYPES): //")
FIRST_CHAR=$(echo "$SUBJECT" | cut -c1)

if ! echo "$FIRST_CHAR" | grep -qE "[A-Z]"; then
  echo ""
  echo "  ✗ COMMIT REJECTED — Subject must start with a capital letter"
  echo ""
  echo "  Your subject: $SUBJECT"
  echo "  Expected:     $(echo "$FIRST_CHAR" | tr '[:lower:]' '[:upper:]')${SUBJECT:1}"
  echo ""
  exit 1
fi

# --- Rule 3: subject must not end with a period ---
LAST_CHAR=$(echo "$SUBJECT" | rev | cut -c1)
if [ "$LAST_CHAR" = "." ]; then
  echo ""
  echo "  ✗ COMMIT REJECTED — Subject must not end with a period"
  echo ""
  echo "  Your subject: $SUBJECT"
  echo ""
  exit 1
fi

# --- Rule 4: subject (full first line) max 50 chars ---
MSG_LENGTH=${#COMMIT_MSG}
if [ "$MSG_LENGTH" -gt 50 ]; then
  echo ""
  echo "  ⚠ WARNING — First line is $MSG_LENGTH chars (recommended max: 50)"
  echo ""
  # Warning only, not blocking
fi

exit 0
