#!/usr/bin/env bash
# Runs lint, type check, and tests before every commit.

set -e

echo "  Running pre-commit checks..."

# 1. ESLint (Airbnb style)
echo "  → ESLint"
npm run lint --silent
if [ $? -ne 0 ]; then
  echo ""
  echo "  ✗ ESLint failed. Run 'npm run lint:fix' to auto-fix."
  exit 1
fi

# 2. TypeScript type check
echo "  → TypeScript"
npm run typecheck --silent
if [ $? -ne 0 ]; then
  echo ""
  echo "  ✗ Type check failed. Fix type errors before committing."
  exit 1
fi

# 3. Unit tests
echo "  → Tests"
npm test --silent
if [ $? -ne 0 ]; then
  echo ""
  echo "  ✗ Tests failed. Fix failing tests before committing."
  exit 1
fi

echo "  ✓ All checks passed"
echo ""
