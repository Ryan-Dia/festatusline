#!/usr/bin/env bash
# Enforces Udacity Git Commit Style Guide
# https://udacity.github.io/git-styleguide/

COMMIT_MSG=$(head -1 "$1")
TYPES="feat|fix|docs|style|refactor|test|chore"

if echo "$COMMIT_MSG" | grep -qE "^(Merge|fixup!|squash!)"; then
  exit 0
fi

if ! echo "$COMMIT_MSG" | grep -qE "^($TYPES): "; then
  echo ""
  echo "  ✗ COMMIT REJECTED — Invalid format"
  echo ""
  echo "  Expected:  <type>: <Subject>"
  echo "  Got:       $COMMIT_MSG"
  echo "  Types:     feat | fix | docs | style | refactor | test | chore"
  echo "  Example:   feat: Add weekly reset timer widget"
  echo ""
  exit 1
fi

SUBJECT=$(echo "$COMMIT_MSG" | sed -E "s/^($TYPES): //")
FIRST_CHAR=$(echo "$SUBJECT" | cut -c1)

if ! echo "$FIRST_CHAR" | grep -qE "[A-Z]"; then
  echo ""
  echo "  ✗ COMMIT REJECTED — Subject must start with a capital letter"
  echo "  Got: $SUBJECT"
  echo ""
  exit 1
fi

LAST_CHAR=$(echo "$SUBJECT" | rev | cut -c1)
if [ "$LAST_CHAR" = "." ]; then
  echo ""
  echo "  ✗ COMMIT REJECTED — Subject must not end with a period"
  echo ""
  exit 1
fi

MSG_LENGTH=${#COMMIT_MSG}
if [ "$MSG_LENGTH" -gt 50 ]; then
  echo "  ⚠ WARNING — First line is $MSG_LENGTH chars (recommended max: 50)"
fi

exit 0
